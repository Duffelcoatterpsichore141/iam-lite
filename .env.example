# Application
APP_NAME=IAM Lite
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-a-random-256-bit-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ID_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql://iam_user:iam_pass@localhost:5432/iam_lite

# Redis
REDIS_URL=redis://localhost:6379/0

# OAuth2 / OIDC
OAUTH2_ISSUER=http://localhost:8000
OAUTH2_AUDIENCE=iam-lite-api

# First Admin User (seed)
FIRST_ADMIN_EMAIL=admin@iam-lite.local
FIRST_ADMIN_PASSWORD=Admin@2025!
