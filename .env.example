# Application
APP_NAME=IAM Lite
APP_ENV=development
DEBUG=false

# Security — generate with: openssl rand -hex 32
SECRET_KEY=your-256-bit-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ID_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql://iam_user:iam_pass@localhost:5432/iam_lite
POSTGRES_USER=iam_user
POSTGRES_PASSWORD=iam_pass
POSTGRES_DB=iam_lite

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# OAuth2 / OIDC
OAUTH2_ISSUER=http://localhost:8000
OAUTH2_AUDIENCE=iam-lite-api

# Initial admin account — required for first run
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=ChangeMe@2025!
